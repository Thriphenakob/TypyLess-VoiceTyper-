# VoiceTyper does not require a .env file for normal usage.
# API keys for ASR/LLM are configured inside the app UI:
#   Settings -> AI Engine
#
# Optional env vars:

# Python model cache directory (default is set in python/engine.py)
HF_HOME="F:\\AI_AGENT\\Models\\voice_model"

# Dev server URL override (usually set automatically by npm run electron:dev)
VOICETYPER_DEV_SERVER_URL="http://127.0.0.1:3000"
